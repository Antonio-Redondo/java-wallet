          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 409', () => pm.response.to.have.status(409));",
                  "const b = pm.response.json();",
                  "pm.test('error body: 409 / Conflict', () => { pm.expect(b.status).to.eql(409); pm.expect(b.error).to.eql('Conflict'); });",
                  "pm.test('has a non-empty message', () => pm.expect(b.message).to.be.a('string').and.to.have.length.above(0));"
                ]
