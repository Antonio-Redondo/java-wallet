          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"idempotencyKey\":\"{{idempotencyKey}}\",\"fromAccountId\":\"{{accountA}}\",\"toAccountId\":\"{{accountB}}\",\"amount\":31.00,\"currency\":\"EUR\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["transfers"]
            }
          }
