                  "pm.test('message mentions insufficient funds', () => pm.expect(String(b.message).toLowerCase()).to.include('insufficient'));",
                  "pm.test('error body carries a timestamp', () => pm.expect(b).to.have.property('timestamp'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"fromAccountId\":\"{{accountA}}\",\"toAccountId\":\"{{accountB}}\",\"amount\":1000000.00,\"currency\":\"EUR\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["transfers"]
            }
          }
        },
        {
          "name": "Currency mismatch -> 422",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 422 (USD on EUR accounts)', () => pm.response.to.have.status(422));",
                  "const b = pm.response.json();",
                  "pm.test('error body: 422 / Unprocessable Entity', () => { pm.expect(b.status).to.eql(422); pm.expect(b.error).to.eql('Unprocessable Entity'); });",
                  "pm.test('has a non-empty message', () => pm.expect(b.message).to.be.a('string').and.to.have.length.above(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"fromAccountId\":\"{{accountA}}\",\"toAccountId\":\"{{accountB}}\",\"amount\":1.00,\"currency\":\"USD\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["transfers"]
            }
          }
        },
        {
